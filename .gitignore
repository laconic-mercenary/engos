# Rust build artifacts — regenerated by `cargo build`; never commit.
/target

# rustfmt backup files — created when `--backup` is passed.
**/*.rs.bk

# `config.toml` contains operator-specific watch paths.
# Commit `config.toml.example` (a template with placeholder values) instead.
config.toml

# Environment variable files — `ENGOS_API_KEY` must never be committed.
.env
*.env

# macOS directory metadata — created by Finder, not part of the project.
.DS_Store

# Editor project directories.
.idea/
.vscode/
*.swp
*.swo
